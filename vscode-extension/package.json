{
  "name": "dependency-chain-substrate",
  "displayName": "Dependency Chain Substrate",
  "description": "Inline DI migration diagnostics (LEAKED, BROKEN, DUPLICATE) via dcs analyze report JSON.",
  "version": "0.1.0",
  "publisher": "dependency-chain-substrate",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:csharp",
    "workspaceContains:**/*.csproj"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dcs.analyze",
        "title": "DCS: Analyze Workspace"
      }
    ],
    "configuration": {
      "title": "Dependency Chain Substrate",
      "properties": {
        "dcs.cliPath": {
          "type": "string",
          "default": "dcs",
          "description": "Path to the dcs CLI executable."
        },
        "dcs.analyzeOnOpen": {
          "type": "boolean",
          "default": true,
          "description": "Run analysis when a C# workspace is opened."
        },
        "dcs.analyzeOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Run analysis when a C# file is saved."
        },
        "dcs.cacheDir": {
          "type": "string",
          "default": "",
          "description": "Optional --cache-dir passed to dcs analyze (empty = CLI default)."
        },
        "dcs.strict": {
          "type": "boolean",
          "default": false,
          "description": "Pass --strict to disable FindingPolicy suppressions."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
