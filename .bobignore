# IBM Bob context exclusions for dependency-chain-substrate
# Uses conservative gitignore-compatible syntax only: comments, directory suffixes,
# root anchors, globstars, and explicit negation. Preserve solution/project files, source, tests, fixtures, docs, and CI.

# Dependencies, package-manager stores, and external modules
/packages/
**/packages/
/.nuget/packages/
/node_modules/
**/node_modules/
/vendor/
.bower_components/
.pnpm-store/
.yarn/cache/
.yarn/unplugged/
.bun/
.venv/
venv/
env/
__pycache__/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.cargo/registry/
.cargo/git/

# .NET, native, and web build outputs
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
/x64/
/x86/
/ARM/
/ARM64/
/artifacts/
/TestResults/
/BenchmarkDotNet.Artifacts/
/publish/
/dist/
**/dist/
/build/
**/build/
/out/
**/out/
/coverage/
**/coverage/
/.next/
**/.next/
/.nuxt/
**/.nuxt/
/.output/
**/.output/
*.dll
*.exe
*.so
*.dylib
*.pdb
*.ilk
*.iobj
*.ipdb
*.nupkg
*.snupkg
*.appx
*.appxbundle
*.msi
*.msix
*.cab
*.wasm
*.map
*.min.js
*.min.css
*.d.ts.map

