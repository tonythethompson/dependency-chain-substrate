# Logs, caches, operating-system files, and IDE metadata
*.log
*.binlog
logs/
*.cache
.cache/
.npm/
.eslintcache
.stylelintcache
.parcel-cache/
.svelte-kit/
.vite/
.vscode/
.idea/
.vs/
_ReSharper*/
_NCrunch_*/
*.iml
*.suo
*.user
*.rsuser
*.sln.docstates
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# Local environment and machine-specific configuration
.env
.env.*
!.env.example
!.env.template
*.local
*.pfx
*.p12
*.key
*.token

# Dependency lockfiles: inspect only for dependency-resolution work
package-lock.json
npm-shrinkwrap.json
yarn.lock
pnpm-lock.yaml
bun.lockb
poetry.lock
Pipfile.lock
uv.lock
Gemfile.lock
composer.lock
Cargo.lock
Podfile.lock
Package.resolved
packages.lock.json
**/packages.lock.json
